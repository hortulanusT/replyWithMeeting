{
    "manifest_version": 3,
    "default_locale": "en-US",
    "name": "__MSG_appName__",
    "description": "__MSG_appDescription__",
    "version": "0.3.1",
    "author": "Til Gärtner",
    "browser_specific_settings": {
        "gecko": {
            "id": "reply-with-meeting@tgartner.local",
            "strict_min_version": "149.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ],
                "optional": []
            }
        }
    },
    "permissions": [
        "messagesRead",
        "accountsRead",
        "notifications",
        "menus"
    ],
    "experiment_apis": {
        "calendarDialog": {
            "schema": "experiments/calendarDialog/schema.json",
            "parent": {
                "scopes": [
                    "addon_parent"
                ],
                "script": "experiments/calendarDialog/implementation.js",
                "paths": [
                    [
                        "calendarDialog"
                    ]
                ]
            }
        }
    },
    "background": {
        "scripts": [
            "src/background.js"
        ],
        "type": "module"
    },
    "message_display_action": {
        "default_title": "__MSG_actionTitle__",
        "default_icon": "icons/reply-with-meeting.svg",
        "theme_icons": [
            {
                "light": "icons/reply-with-meeting-light.svg",
                "dark": "icons/reply-with-meeting-dark.svg",
                "size": 32
            }
        ]
    },
    "icons": {
        "16": "icons/reply-with-meeting.svg",
        "32": "icons/reply-with-meeting.svg",
        "64": "icons/reply-with-meeting.svg"
    }
}